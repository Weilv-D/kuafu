# ============================================================
# KUAFU — 版本控制忽略规则
# ============================================================

# ---- CAD 模型(体积大,单独管理)----
3Dmodel/

# ---- 训练日志 ----
train.log
train_*.log

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- 分析中间数据(可由 run_all.py 重新生成)----
analysis/output/

# ---- RL 训练产物(大文件, 不进库)----
rl/checkpoints/
rl/.jax_cache/
rl/wandb/
rl/runs/
*.onnx
*.onnx.data
*.pt
*.ckpt

# ---- 环境 / 编辑器 ----
.venv/
venv/
/env/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 系统 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- SolidWorks 临时文件 ----
~$*.SLDASM
~$*.SLDPRT
~$*.SLDDRW
MUJOCO_LOG.TXT
logs/
*.bak

# ---- Keil MDK-ARM ----
stm32_firmware/**/Listings/
stm32_firmware/**/Objects/
stm32_firmware/**/RTE/
stm32_firmware/**/DebugConfig/
stm32_firmware/**/F407ZG/
stm32_firmware/**/stm32_firmware/
!stm32_firmware/**/*.sct
stm32_firmware/**/*.uvguix.*
stm32_firmware/**/*.uv2.local
stm32_firmware/**/*.dep
stm32_firmware/**/*.crf
stm32_firmware/**/*.d
stm32_firmware/**/*.o
stm32_firmware/**/*.axf
stm32_firmware/**/*.hex
stm32_firmware/**/*.bin
stm32_firmware/**/*.lnp
stm32_firmware/**/*.htm
stm32_firmware/**/*.build_log.htm
stm32_firmware/**/*.map
stm32_firmware/**/*.lst
